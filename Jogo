const TILE = 32

function getTile(x,y){

let seed = Math.sin(x*12.9898 + y*78.233)*43758.5453
let n = seed - Math.floor(seed)

if(n < 0.2) return "water"
if(n < 0.4) return "forest"
if(n < 0.6) return "grass"
if(n < 0.8) return "desert"

return "mountain"

}

function drawWorld(){

let startX = Math.floor(player.x / TILE) - 20
let startY = Math.floor(player.y / TILE) - 15

for(let x=startX; x<startX+40; x++){
for(let y=startY; y<startY+30; y++){

let tile = getTile(x,y)

if(tile=="grass") ctx.fillStyle="#2ecc71"
if(tile=="forest") ctx.fillStyle="#145a32"
if(tile=="water") ctx.fillStyle="#3498db"
if(tile=="desert") ctx.fillStyle="#f4d03f"
if(tile=="mountain") ctx.fillStyle="#888"

ctx.fillRect(
(x*TILE)-player.x+canvas.width/2,
(y*TILE)-player.y+canvas.height/2,
TILE,TILE
)

}
}

}function enemyAI(enemy){

let dx = player.x - enemy.x
let dy = player.y - enemy.y
let dist = Math.sqrt(dx*dx+dy*dy)

if(dist < 250){

enemy.state = "chase"

}

if(enemy.state=="chase"){

enemy.x += dx*0.02
enemy.y += dy*0.02

}

if(dist < 60){

player.hp -= 0.2

}

